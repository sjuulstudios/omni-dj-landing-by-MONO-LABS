# Copy to .env and fill in. NEVER commit .env.

# Server
PORT=5556
FLASK_DEBUG=0
ALLOWED_ORIGINS=https://omnidj.com,http://localhost:3000

# SMTP (Postmark / SendGrid / your provider)
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=hello@omnidj.com

# Where each role's contact message lands
CONTACT_INBOX_DEFAULT=support@omnidj.com
CONTACT_INBOX_DJ=hello@omnidj.com
CONTACT_INBOX_TALENT=sales@omnidj.com
CONTACT_INBOX_VIDEO=hello@omnidj.com
CONTACT_INBOX_EVENT=sales@omnidj.com
CONTACT_INBOX_LABEL=sales@omnidj.com
