<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Hardened-runtime entitlements voor Omni DJ.

        Vereist door Apple notarization. Geeft de gebundelde Python +
        ffmpeg toestemming om:
            - JIT/eval te draaien (numba compileert at runtime).
            - Onsigned dynamic libraries te laden (librosa shared libs).
            - Netwerk te gebruiken (Stripe-checkout, Supabase, social
              platform OAuth, watch-folder updates).
            - Audio in te lezen via systeem-audio APIs.
        Geen DEBUGGER entitlement — die schakelt sandbox-protecties uit.
    -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <key>com.apple.security.network.client</key>
    <true/>

    <key>com.apple.security.network.server</key>
    <true/>

    <key>com.apple.security.device.audio-input</key>
    <true/>

    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!--
        SESSIE 69 — apple-events entitlement.
        De osascript file/folder-picker ('choose file'/'choose folder') is een
        Apple-Event. Onder de hardened runtime wordt die zonder dit entitlement
        geblokkeerd, waardoor het dialog nergens opent en /api/pick-file hangt.
        De primaire picker is nu NSOpenPanel (in-proces, geen Apple-Event),
        maar dit entitlement houdt de osascript-fallback werkend.
    -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
</dict>
</plist>
